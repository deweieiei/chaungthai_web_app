# ChaungThai Web — copy เป็น .env แล้วแก้ค่าตามต้องการ

PORT=8086
NODE_ENV=development

# Backend API ที่จะ proxy ไป (Express forward /api/* → ตรงนี้)
# - บน server เดียวกัน: ใช้ http://localhost:3000 (เร็ว, ไม่มี cert issue)
# - จากนอก: ใช้ https://110.171.128.44 (อาจมี cert issue ถ้า self-signed)
API_TARGET=http://localhost:3000
