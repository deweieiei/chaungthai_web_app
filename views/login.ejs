<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="container">
  <div class="card">
    <h1>เข้าสู่ระบบ</h1>
    <form onsubmit="doLogin(event)">
      <label>อีเมล</label>
      <input name="user_email" type="email" required>

      <label>รหัสผ่าน</label>
      <input name="user_password" type="password" required>

      <div class="actions">
        <button type="submit" class="btn">เข้าสู่ระบบ</button>
        <a href="/register" class="btn secondary">ยังไม่มีบัญชี? สมัครเลย</a>
      </div>
    </form>
    <div id="msg"></div>
  </div>
</div>

<script>
async function doLogin(e) {
  e.preventDefault();
  const fd = new FormData(e.target);
  const body = Object.fromEntries(fd.entries());

  const { ok, status, data } = await apiCall('/auth/login', {
    method: 'POST',
    body,
  });

  const msg = document.getElementById('msg');
  if (ok) {
    setToken(data.token);
    setUser(data.user);
    msg.innerHTML = '<div class="alert success">เข้าสู่ระบบสำเร็จ! กำลังพาไปหน้าหลัก...</div>';
    setTimeout(() => window.location.href = '/home', 800);
  } else {
    msg.innerHTML = '<div class="alert error">' + (data?.error || 'เกิดข้อผิดพลาด') + '</div>';
  }
}
</script>

<%- include('partials/footer') %>
