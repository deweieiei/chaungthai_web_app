<%- include('../partials/head') %>
<div class="app-shell">
  <div class="page-content page-content--narrow">
    <div class="text-center" style="margin-top: var(--space-xl);">
      <div class="brand-mark">
        <img src="/static/images/logo.png" alt="ChaungThai" width="96" height="96">
      </div>
      <h1 style="font-weight: 800;">ยินดีต้อนรับกลับ</h1>
      <p class="text-muted">เข้าสู่ระบบเพื่อใช้งาน ChaungThai</p>
    </div>

    <form id="login-form" novalidate style="margin-top: var(--space-xl);">
      <div data-form-error></div>

      <div class="field">
        <label class="field__label" for="email">อีเมล</label>
        <div class="input-group">
          <span class="input-group__icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 5L2 7"/></svg>
          </span>
          <input class="input" type="email" id="email" name="email" autocomplete="email" inputmode="email" placeholder="you@example.com">
        </div>
        <div class="field__error" id="email-error"></div>
      </div>

      <div class="field">
        <label class="field__label" for="password">รหัสผ่าน</label>
        <div class="input-group">
          <span class="input-group__icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </span>
          <input class="input" type="password" id="password" name="password" autocomplete="current-password" placeholder="••••••••">
          <button type="button" class="input-group__trail" data-toggle-password aria-label="แสดงรหัสผ่าน">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
          </button>
        </div>
        <div class="field__error" id="password-error"></div>
      </div>

      <div style="text-align: right; margin-top: -8px; margin-bottom: var(--space-md);">
        <a href="/forgot-password" class="text-small">ลืมรหัสผ่าน?</a>
      </div>

      <button type="submit" class="btn btn--primary btn--block btn--lg">เข้าสู่ระบบ</button>
    </form>

    <div class="divider">หรือ</div>

    <a href="/register" class="btn btn--outline btn--block">สมัครสมาชิกใหม่</a>

    <div class="text-center" style="margin-top: var(--space-lg);">
      <a href="/" class="text-small text-muted">‹ กลับหน้าแรก</a>
    </div>
  </div>
</div>
<%- include('../partials/foot', { pageScript: 'login' }) %>
