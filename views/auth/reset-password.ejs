<%- include('../partials/head') %>
<div class="app-shell app-shell--with-header">
  <%- include('../partials/header', { title: 'ตั้งรหัสผ่านใหม่', back: true, backHref: '/login' }) %>
  <div class="page-content page-content--narrow">
    <div class="text-center" style="margin-top: var(--space-md);">
      <div style="width: 80px; height: 80px; margin: 0 auto var(--space-md); background: var(--primary-soft); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--primary);">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777Zm0 0L15.5 7.5m0 0 3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
      </div>
      <h2 style="font-weight: 800;">ตั้งรหัสผ่านใหม่</h2>
      <p class="text-muted">เลือกรหัสผ่านที่จำง่ายและปลอดภัย</p>
    </div>

    <form id="reset-form" novalidate style="margin-top: var(--space-lg);">
      <div data-form-error></div>
      <input type="hidden" id="reset-token" value="<%= token %>">

      <div class="field">
        <label class="field__label" for="new-password">รหัสผ่านใหม่</label>
        <input class="input" type="password" id="new-password" name="new-password" autocomplete="new-password" placeholder="อย่างน้อย 8 ตัว">
        <span class="field__hint">อย่างน้อย 8 ตัวอักษร</span>
        <div class="field__error" id="new-password-error"></div>
      </div>

      <div class="field">
        <label class="field__label" for="confirm">ยืนยันรหัสผ่านใหม่</label>
        <input class="input" type="password" id="confirm" name="confirm" autocomplete="new-password" placeholder="กรอกอีกครั้ง">
        <div class="field__error" id="confirm-error"></div>
      </div>

      <button type="submit" class="btn btn--primary btn--block btn--lg">บันทึกรหัสผ่านใหม่</button>
    </form>
  </div>
</div>
<%- include('../partials/foot', { pageScript: 'reset-password' }) %>
