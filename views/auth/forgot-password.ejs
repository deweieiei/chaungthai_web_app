<%- include('../partials/head') %>
<div class="app-shell app-shell--with-header">
  <%- include('../partials/header', { title: 'ลืมรหัสผ่าน', back: true, backHref: '/login' }) %>
  <div class="page-content page-content--narrow">
    <div class="text-center" style="margin-top: var(--space-md);">
      <div style="font-size: 56px; color: var(--primary);">🔑</div>
      <p class="text-muted">กรอกอีเมลที่ใช้สมัครสมาชิก เราจะส่งลิงก์รีเซ็ตให้</p>
    </div>

    <form id="forgot-form" novalidate style="margin-top: var(--space-lg);">
      <div data-form-error></div>

      <div class="field">
        <label class="field__label" for="email">อีเมล</label>
        <div class="input-group">
          <span class="input-group__icon">✉</span>
          <input class="input" type="email" id="email" name="email" autocomplete="email" inputmode="email">
        </div>
        <div class="field__error" id="email-error"></div>
      </div>

      <button type="submit" class="btn btn--primary btn--block">ส่งลิงก์รีเซ็ตรหัสผ่าน</button>
    </form>

    <div id="result-area" class="hidden" style="margin-top: var(--space-md);"></div>

    <div class="text-center" style="margin-top: var(--space-md);">
      <a href="/login" class="text-small">กลับไปหน้าเข้าสู่ระบบ</a>
    </div>
  </div>
</div>
<%- include('../partials/foot', { pageScript: 'forgot-password' }) %>
