<%- include('../partials/head') %>
<div class="app-shell app-shell--with-header">
  <%- include('../partials/header', { title: 'ลืมรหัสผ่าน', back: true, backHref: '/login' }) %>
  <div class="page-content page-content--narrow">
    <div class="text-center" style="margin-top: var(--space-md);">
      <div style="width: 80px; height: 80px; margin: 0 auto var(--space-md); background: var(--primary-soft); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--primary);">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="16" r="1"/><rect x="3" y="10" width="18" height="12" rx="2"/><path d="M7 10V6a5 5 0 0 1 10 0v4"/></svg>
      </div>
      <h2 style="font-weight: 800;">ลืมรหัสผ่าน?</h2>
      <p class="text-muted">กรอกอีเมลที่ใช้สมัครสมาชิก<br>เราจะส่งลิงก์รีเซ็ตให้</p>
    </div>

    <form id="forgot-form" novalidate style="margin-top: var(--space-lg);">
      <div data-form-error></div>

      <div class="field">
        <label class="field__label" for="email">อีเมล</label>
        <div class="input-group">
          <span class="input-group__icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 5L2 7"/></svg>
          </span>
          <input class="input" type="email" id="email" name="email" autocomplete="email" inputmode="email" placeholder="you@example.com">
        </div>
        <div class="field__error" id="email-error"></div>
      </div>

      <button type="submit" class="btn btn--primary btn--block btn--lg">ส่งลิงก์รีเซ็ต</button>
    </form>

    <div id="result-area" class="hidden" style="margin-top: var(--space-md);"></div>

    <div class="text-center" style="margin-top: var(--space-lg);">
      <a href="/login" class="text-small">‹ กลับไปหน้าเข้าสู่ระบบ</a>
    </div>
  </div>
</div>
<%- include('../partials/foot', { pageScript: 'forgot-password' }) %>
