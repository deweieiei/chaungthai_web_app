<%- include('../partials/head') %>
<div class="app-shell app-shell--with-header">
  <%- include('../partials/header', { title: 'สมัครสมาชิก', back: true, backHref: '/login' }) %>
  <div class="page-content page-content--narrow">
    <div class="text-center" style="margin-bottom: var(--space-lg);">
      <div class="brand-mark brand-mark--sm" style="margin: 0 auto var(--space-sm);">
        <img src="/static/images/logo.png" alt="" width="44" height="44">
      </div>
      <h2 style="font-weight: 800; margin-bottom: 2px;">สร้างบัญชีใหม่</h2>
      <p class="text-small text-muted" id="reg-lead">เริ่มใช้งาน ช่างไทย ฟรี</p>
    </div>

    <!-- ขั้นที่ 1: จะสมัครฝั่งไหน -->
    <div id="side-picker">
      <button type="button" class="sidebtn" data-side="employer">
        <span class="sidebtn__ico">🔍</span>
        <span class="sidebtn__body">
          <span class="sidebtn__title">สมัครเป็นผู้ว่าจ้าง</span>
          <span class="sidebtn__sub">หาช่างมาทำงานให้</span>
        </span>
        <span class="sidebtn__go">›</span>
      </button>
      <button type="button" class="sidebtn" data-side="worker">
        <span class="sidebtn__ico">🛠️</span>
        <span class="sidebtn__body">
          <span class="sidebtn__title">สมัครเป็นช่าง</span>
          <span class="sidebtn__sub">รับงาน ขึ้นแผนที่ให้คนหาเจอ</span>
        </span>
        <span class="sidebtn__go">›</span>
      </button>
      <p class="text-tiny text-muted text-center" style="margin-top: var(--space-md);">
        2 ฝั่งเป็นคนละบัญชีกัน · อีเมลเดียวกันสมัครได้ทั้งคู่ · สมัครอีกฝั่งทีหลังก็ได้
      </p>
    </div>

    <form id="register-form" novalidate hidden>
      <div class="sidebadge" id="side-badge">
        <span id="side-badge-text"></span>
        <button type="button" id="side-change">เปลี่ยน</button>
      </div>

      <div data-form-error></div>

      <div class="field">
        <label class="field__label" for="name">ชื่อ <span class="text-danger">*</span></label>
        <input class="input" type="text" id="name" name="name" autocomplete="given-name" placeholder="ชื่อจริง">
        <div class="field__error" id="name-error"></div>
      </div>

      <div class="field">
        <label class="field__label" for="lastname">นามสกุล</label>
        <input class="input" type="text" id="lastname" name="lastname" autocomplete="family-name" placeholder="นามสกุล (ไม่บังคับ)">
      </div>

      <div class="field">
        <label class="field__label" for="email">อีเมล <span class="text-danger">*</span></label>
        <input class="input" type="email" id="email" name="email" autocomplete="email" inputmode="email" placeholder="you@example.com">
        <div class="field__error" id="email-error"></div>
      </div>

      <div class="field">
        <label class="field__label" for="password">รหัสผ่าน <span class="text-danger">*</span></label>
        <div class="input-group">
          <input class="input" type="password" id="password" name="password" autocomplete="new-password" placeholder="อย่างน้อย 8 ตัว">
          <button type="button" class="input-group__trail" data-toggle-password aria-label="แสดงรหัสผ่าน">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
          </button>
        </div>
        <span class="field__hint">อย่างน้อย 8 ตัวอักษร — ใส่ตัวเลขและอักษรพิเศษเพิ่มความปลอดภัย</span>
        <div class="field__error" id="password-error"></div>
      </div>

      <div class="field">
        <label class="field__label" for="confirm">ยืนยันรหัสผ่าน <span class="text-danger">*</span></label>
        <input class="input" type="password" id="confirm" name="confirm" autocomplete="new-password" placeholder="กรอกรหัสผ่านอีกครั้ง">
        <div class="field__error" id="confirm-error"></div>
      </div>

      <div class="field" style="margin-top: var(--space-md);">
        <label class="check" for="agree">
          <input type="checkbox" id="agree" name="agree">
          <span class="check__box" aria-hidden="true"></span>
          <span class="check__label">
            ฉันยอมรับ <a href="/terms" target="_blank" rel="noopener">ข้อตกลงการใช้งาน</a>
            และ <a href="/privacy" target="_blank" rel="noopener">นโยบายความเป็นส่วนตัว</a>
          </span>
        </label>
        <div class="field__error" id="agree-error"></div>
      </div>

      <button type="submit" class="btn btn--primary btn--block btn--lg" id="reg-submit" style="margin-top: var(--space-md);">สมัครสมาชิก</button>
    </form>

    <div class="divider">มีบัญชีอยู่แล้ว?</div>
    <a href="/login" class="btn btn--outline btn--block">เข้าสู่ระบบ</a>
  </div>
</div>
<%- include('../partials/foot', { pageScript: 'register' }) %>
