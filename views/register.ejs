<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="container">
  <div class="card">
    <h1>สมัครสมาชิก</h1>
    <form onsubmit="doRegister(event)">
      <label>ชื่อ <small class="hint">*</small></label>
      <input name="user_name" required>

      <label>นามสกุล</label>
      <input name="user_lastname">

      <label>อีเมล <small class="hint">*</small></label>
      <input name="user_email" type="email" required>

      <label>รหัสผ่าน <small class="hint">* อย่างน้อย 8 ตัว</small></label>
      <input name="user_password" type="password" minlength="8" required>

      <div class="actions">
        <button type="submit" class="btn">สมัคร</button>
        <a href="/login" class="btn secondary">มีบัญชีแล้ว เข้าสู่ระบบ</a>
      </div>
    </form>
    <div id="msg"></div>
  </div>
</div>

<script>
async function doRegister(e) {
  e.preventDefault();
  const fd = new FormData(e.target);
  const body = Object.fromEntries(fd.entries());

  const { ok, status, data } = await apiCall('/auth/register', {
    method: 'POST',
    body,
  });

  const msg = document.getElementById('msg');
  if (ok) {
    msg.innerHTML = '<div class="alert success">สมัครสำเร็จ! กำลังพาไปหน้า login...</div>';
    setTimeout(() => window.location.href = '/login', 1200);
  } else {
    msg.innerHTML = '<div class="alert error">' + (data?.error || 'เกิดข้อผิดพลาด') + '</div>';
  }
}
</script>

<%- include('partials/footer') %>
