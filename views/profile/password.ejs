<%- include('../partials/head') %>
<div class="app-shell app-shell--with-header">
  <%- include('../partials/header', { title: 'เปลี่ยนรหัสผ่าน', back: true, backHref: '/profile' }) %>
  <div class="page-content page-content--narrow">
    <div class="text-center" style="margin-top: var(--space-md); margin-bottom: var(--space-lg);">
      <div style="width: 72px; height: 72px; margin: 0 auto var(--space-md); background: var(--primary-soft); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--primary);">
        <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      </div>
      <h2 style="font-weight: 800;">เปลี่ยนรหัสผ่าน</h2>
      <p class="text-small text-muted">เพื่อความปลอดภัยของบัญชีคุณ</p>
    </div>

    <form id="password-form" novalidate>
      <div data-form-error></div>

      <div class="field">
        <label class="field__label" for="old">รหัสผ่านเดิม</label>
        <input class="input" type="password" id="old" autocomplete="current-password" placeholder="รหัสผ่านปัจจุบัน">
        <div class="field__error" id="old-error"></div>
      </div>

      <div class="field">
        <label class="field__label" for="new">รหัสผ่านใหม่</label>
        <input class="input" type="password" id="new" autocomplete="new-password" placeholder="อย่างน้อย 8 ตัว">
        <span class="field__hint">อย่างน้อย 8 ตัวอักษร</span>
        <div class="field__error" id="new-error"></div>
      </div>

      <div class="field">
        <label class="field__label" for="confirm">ยืนยันรหัสผ่านใหม่</label>
        <input class="input" type="password" id="confirm" autocomplete="new-password" placeholder="กรอกอีกครั้ง">
        <div class="field__error" id="confirm-error"></div>
      </div>

      <button type="submit" class="btn btn--primary btn--block btn--lg" style="margin-top: var(--space-md);">เปลี่ยนรหัสผ่าน</button>
    </form>
  </div>
</div>
<%- include('../partials/foot', { pageScript: 'profile-password' }) %>
