<%- include('partials/head') %>
<div class="app-shell">
  <div class="page-content page-content--lg" style="display:flex; flex-direction:column; min-height:100dvh;">
    <div class="text-center" style="margin-top: var(--space-xl);">
      <div class="brand-mark brand-mark--lg">
        <img src="/static/images/logo.png" alt="ChaungThai" width="128" height="128">
      </div>
      <h1 class="text-gradient" style="font-weight: 900; font-size: 2rem; margin-bottom: 4px;">ChaungThai</h1>
      <p class="text-muted" style="font-size: 0.95rem;">จับคู่คนเก่งกับคนมีปัญหา<br>ในราคาที่จ่ายไหว</p>
    </div>

    <div style="margin-top: var(--space-xl);">
      <div class="feature-row">
        <div class="feature-row__icon">🔧</div>
        <div>
          <p class="feature-row__title">ช่างมืออาชีพในพื้นที่</p>
          <p class="feature-row__sub">ค้นหาช่างใกล้บ้านด้วยจังหวัด-ตำบล</p>
        </div>
      </div>
      <div class="feature-row">
        <div class="feature-row__icon">⚡</div>
        <div>
          <p class="feature-row__title">เลือกสกิลตรงงาน</p>
          <p class="feature-row__sub">มีสกิลย่อย 189 รายการ ครอบคลุมทุกงาน</p>
        </div>
      </div>
      <div class="feature-row">
        <div class="feature-row__icon">💬</div>
        <div>
          <p class="feature-row__title">ติดต่อตรง ไม่ผ่านคนกลาง</p>
          <p class="feature-row__sub">คุยกับช่างได้โดยตรง โปร่งใส</p>
        </div>
      </div>
    </div>

    <div style="margin-top: auto; padding-top: var(--space-xl);">
      <a href="/login" class="btn btn--primary btn--block btn--lg">เข้าสู่ระบบ</a>
      <div style="height: var(--space-sm);"></div>
      <a href="/register" class="btn btn--outline btn--block btn--lg">สมัครสมาชิก</a>
      <p class="text-tiny text-faint text-center" style="margin-top: var(--space-md);">
        การใช้งานถือว่ายอมรับข้อตกลงและนโยบายความเป็นส่วนตัว
      </p>
    </div>
  </div>
</div>
<script src="/static/js/auth.js?v=<%= assetV %>"></script>
<script>
  if (window.Auth && window.Auth.isLoggedIn()) location.replace('/home');
</script>
</body>
</html>
