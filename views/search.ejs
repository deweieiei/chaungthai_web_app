<%- include('partials/head') %>
<div class="app-shell app-shell--with-nav">
  <%- include('partials/app-nav', { activeTab: 'search' }) %>
  <div class="page-content">
    <div style="margin-bottom: var(--space-md);">
      <h2 style="margin-bottom: 4px;">หาช่าง</h2>
      <p class="text-small text-muted" style="margin: 0;">เลือกความสามารถที่ต้องการ แล้วกำหนดพื้นที่บนแผนที่</p>
    </div>

    <div class="card card--elevated">
      <h4 class="card__title" style="margin-bottom: var(--space-sm);">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--primary);" aria-hidden="true"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76Z"/></svg>
        ความสามารถที่ต้องการ
      </h4>

      <div class="field">
        <label class="field__label" for="category">หมวดหมู่</label>
        <select class="select" id="category">
          <option value="">— ทั้งหมด —</option>
        </select>
      </div>

      <div class="field">
        <label class="field__label" for="subcategory">สกิลหลัก / สาขา</label>
        <select class="select" id="subcategory" disabled>
          <option value="">— ทั้งหมด —</option>
        </select>
      </div>

      <div class="field" style="margin-bottom: 0;">
        <label class="field__label" for="skill">สกิลย่อย</label>
        <select class="select" id="skill" disabled>
          <option value="">— ทั้งหมด —</option>
        </select>
        <div class="field__error" id="skill-error"></div>
      </div>
    </div>

    <div class="card card--elevated">
      <h4 class="card__title" style="margin-bottom: var(--space-sm);">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--primary);" aria-hidden="true"><path d="M20 10c0 7-8 12-8 12s-8-5-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
        พื้นที่ที่ต้องการหา
      </h4>

      <div class="field">
        <label class="field__label" for="radius">ระยะทางจากจุดที่เลือก</label>
        <select class="select" id="radius">
          <option value="5">ไม่เกิน 5 กม.</option>
          <option value="10" selected>ไม่เกิน 10 กม.</option>
          <option value="20">ไม่เกิน 20 กม.</option>
          <option value="50">ไม่เกิน 50 กม.</option>
          <option value="100">ไม่เกิน 100 กม.</option>
        </select>
      </div>

      <div class="pinbox">
        <div class="pinbox__map" id="area-map"></div>
        <div class="pinbox__foot">
          <span class="pinbox__coord" id="area-coord">กำลังหาตำแหน่ง…</span>
          <button type="button" class="mapbar__locate" id="btn-here">🎯 ตำแหน่งฉัน</button>
        </div>
      </div>
      <p class="pinbox__hint">แตะบนแผนที่หรือลากหมุด เพื่อเลือกจุดที่อยากหาช่างรอบ ๆ</p>
    </div>

    <button class="btn btn--primary btn--block btn--lg" id="search-btn" style="margin-top: var(--space-md);">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
      ค้นหา
    </button>

    <div id="results-area"></div>
  </div>
  <%- include('partials/bottom-nav', { activeTab: 'search' }) %>
</div>
<script src="/static/js/map.js?v=<%= assetV %>"></script>
<%- include('partials/foot', { pageScript: 'search' }) %>
