<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="container">
  <div class="card">
    <h1>โปรไฟล์ของฉัน</h1>

    <!-- รูปโปรไฟล์ -->
    <div style="display:flex; gap:20px; align-items:center; margin-bottom:20px;">
      <img id="avatar-preview" src="" alt="avatar"
           style="width:120px; height:120px; border-radius:50%; object-fit:cover; background:#eee; border:2px solid #ddd;">
      <div>
        <label style="margin-top:0;">รูปโปรไฟล์</label>
        <input type="file" id="avatar-file" accept="image/jpeg,image/png,image/webp" onchange="onAvatarChange(event)">
        <small class="hint">jpg / png / webp, ไม่เกิน 5MB</small>
        <div id="upload-msg" style="margin-top:8px;"></div>
      </div>
    </div>

    <hr style="margin: 16px 0;">

    <form onsubmit="doUpdate(event)">
      <label>ชื่อ</label>
      <input name="user_name" id="f_user_name">

      <label>นามสกุล</label>
      <input name="user_lastname" id="f_user_lastname">

      <label>เบอร์โทร</label>
      <input name="user_phone" id="f_user_phone">

      <label>วันเกิด (YYYY-MM-DD)</label>
      <input name="user_birthday" id="f_user_birthday" placeholder="2001-05-09">

      <label>แนะนำตัว (bio)</label>
      <textarea name="user_bio" id="f_user_bio"></textarea>

      <hr style="margin: 20px 0;">
      <h2>ที่อยู่</h2>

      <label>จังหวัด</label>
      <select name="user_province_id" id="f_user_province_id" onchange="onProvinceChange()">
        <option value="">-- เลือกจังหวัด --</option>
      </select>

      <label>อำเภอ/เขต</label>
      <select name="user_district_id" id="f_user_district_id" onchange="onDistrictChange()">
        <option value="">-- เลือกอำเภอ --</option>
      </select>

      <label>ตำบล/แขวง</label>
      <select name="user_subdistrict_id" id="f_user_subdistrict_id">
        <option value="">-- เลือกตำบล --</option>
      </select>

      <label>ที่อยู่ (บ้านเลขที่/ซอย/ถนน)</label>
      <input name="user_address" id="f_user_address">

      <div class="actions">
        <button type="submit" class="btn success">บันทึก</button>
      </div>
    </form>
    <div id="msg"></div>
  </div>
</div>

<script>
let currentUser = null;

(async () => {
  const user = getUser();
  if (!user) { window.location.href = '/login'; return; }

  // โหลด user ล่าสุดจาก API
  const { ok, data } = await apiCall('/users/' + user.user_id);
  if (!ok) {
    document.getElementById('msg').innerHTML = '<div class="alert error">โหลดโปรไฟล์ไม่ได้</div>';
    return;
  }
  currentUser = data.user;
  fillForm(currentUser);

  // โหลด provinces
  const provRes = await apiCall('/locations/provinces');
  const provSel = document.getElementById('f_user_province_id');
  for (const p of provRes.data.provinces) {
    const opt = document.createElement('option');
    opt.value = p.province_id;
    opt.textContent = p.province_name_th;
    provSel.appendChild(opt);
  }
  if (currentUser.user_province_id) {
    provSel.value = currentUser.user_province_id;
    await loadDistricts(currentUser.user_province_id, currentUser.user_district_id);
    if (currentUser.user_district_id) {
      await loadSubdistricts(currentUser.user_district_id, currentUser.user_subdistrict_id);
    }
  }
})();

function fillForm(u) {
  ['user_name','user_lastname','user_phone','user_birthday','user_bio','user_address'].forEach(k => {
    const el = document.getElementById('f_' + k);
    if (el) el.value = (k === 'user_birthday' && u[k]) ? u[k].substring(0,10) : (u[k] || '');
  });
  // รูปโปรไฟล์
  const img = document.getElementById('avatar-preview');
  if (u.user_image) {
    // user_image อาจเป็น "/api/uploads/..." (relative) หรือ URL เต็ม
    if (u.user_image.startsWith('http')) img.src = u.user_image;
    else img.src = window.API_BASE_URL.replace(/\/api$/, '') + u.user_image;
  } else {
    // placeholder transparent
    img.src = 'data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="120" height="120" viewBox="0 0 120 120"><rect width="120" height="120" fill="%23e0e0e0"/><text x="50%" y="55%" text-anchor="middle" font-size="40" fill="%23999">?</text></svg>';
  }
}

async function onAvatarChange(e) {
  const file = e.target.files[0];
  if (!file) return;
  const msg = document.getElementById('upload-msg');
  const user = getUser();

  // preview รูปก่อน upload
  document.getElementById('avatar-preview').src = URL.createObjectURL(file);

  msg.innerHTML = '<div class="alert info">กำลังอัปโหลด...</div>';

  // multipart form
  const fd = new FormData();
  fd.append('image', file);

  try {
    const res = await fetch(window.API_BASE_URL + '/users/' + user.user_id + '/image', {
      method: 'POST',
      headers: { 'Authorization': 'Bearer ' + getToken() },
      body: fd,  // FormData -> browser ตั้ง Content-Type พร้อม boundary ให้
    });
    const data = await res.json().catch(() => ({}));
    if (res.ok) {
      msg.innerHTML = '<div class="alert success">อัปโหลดสำเร็จ (' + Math.round((data.size_bytes || 0)/1024) + ' KB)</div>';
      // refresh preview จาก URL ใหม่
      currentUser.user_image = data.user_image;
      fillForm(currentUser);
    } else {
      msg.innerHTML = '<div class="alert error">' + (data?.error || 'อัปโหลดผิดพลาด') + '</div>';
    }
  } catch (err) {
    msg.innerHTML = '<div class="alert error">' + err.message + '</div>';
  }
  e.target.value = ''; // reset input
}

async function loadDistricts(provinceId, selectedId) {
  const sel = document.getElementById('f_user_district_id');
  sel.innerHTML = '<option value="">-- เลือกอำเภอ --</option>';
  const { data } = await apiCall('/locations/districts?province_id=' + provinceId);
  for (const d of data.districts) {
    const opt = document.createElement('option');
    opt.value = d.district_id;
    opt.textContent = d.district_name_th;
    sel.appendChild(opt);
  }
  if (selectedId) sel.value = selectedId;
}

async function loadSubdistricts(districtId, selectedId) {
  const sel = document.getElementById('f_user_subdistrict_id');
  sel.innerHTML = '<option value="">-- เลือกตำบล --</option>';
  const { data } = await apiCall('/locations/subdistricts?district_id=' + districtId);
  for (const s of data.subdistricts) {
    const opt = document.createElement('option');
    opt.value = s.subdistrict_id;
    opt.textContent = s.subdistrict_name_th + ' (' + s.subdistrict_zip_code + ')';
    sel.appendChild(opt);
  }
  if (selectedId) sel.value = selectedId;
}

async function onProvinceChange() {
  const pid = document.getElementById('f_user_province_id').value;
  document.getElementById('f_user_district_id').innerHTML = '<option value="">-- เลือกอำเภอ --</option>';
  document.getElementById('f_user_subdistrict_id').innerHTML = '<option value="">-- เลือกตำบล --</option>';
  if (pid) await loadDistricts(pid);
}
async function onDistrictChange() {
  const did = document.getElementById('f_user_district_id').value;
  document.getElementById('f_user_subdistrict_id').innerHTML = '<option value="">-- เลือกตำบล --</option>';
  if (did) await loadSubdistricts(did);
}

async function doUpdate(e) {
  e.preventDefault();
  const fd = new FormData(e.target);
  const body = {};
  for (const [k, v] of fd.entries()) {
    if (v === '') continue;
    if (k.endsWith('_id')) body[k] = Number(v);
    else body[k] = v;
  }
  const user = getUser();
  const { ok, data } = await apiCall('/users/' + user.user_id, { method: 'PUT', body });
  const msg = document.getElementById('msg');
  if (ok) {
    msg.innerHTML = '<div class="alert success">บันทึกสำเร็จ — updated: ' + (data.updated_fields || []).join(', ') + '</div>';
  } else {
    msg.innerHTML = '<div class="alert error">' + (data?.error || 'ผิดพลาด') + '</div>';
  }
}
</script>

<%- include('partials/footer') %>
