<%- include('../partials/head') %>
<div class="app-shell app-shell--with-header chat-page">
  <header class="app-header chat-header">
    <button type="button" class="app-header__back" onclick="history.back()" aria-label="ย้อนกลับ">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
    </button>
    <a href="#" class="chat-header__peer" id="chat-peer-link" aria-label="ดูโปรไฟล์">
      <span class="chat-header__avatar" id="chat-peer-avatar">
        <span class="avatar avatar--sm">?</span>
      </span>
      <span class="chat-header__info">
        <span class="chat-header__name" id="chat-peer-name">กำลังโหลด...</span>
      </span>
    </a>
    <span class="app-header__action" aria-hidden="true"></span>
  </header>

  <div class="chat-body" id="chat-body" data-target-user-id="<%= targetUserId %>">
    <div class="loading-block"><div class="spinner"></div><div>กำลังเปิดห้องแชต...</div></div>
  </div>
  <!-- typing indicator: ลบ UI แต่คง backend ไว้ — จะกลับมาเปิดได้ทีหลังถ้าต้องการ -->

  <form class="chat-composer" id="chat-composer" autocomplete="off">
    <button type="button" class="chat-composer__action" id="chat-hire-btn" disabled aria-label="จ้างงาน" title="จ้างงาน" hidden>
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 7h-3V5a2 2 0 0 0-2-2H9a2 2 0 0 0-2 2v2H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/><path d="M9 5h6v2H9z"/></svg>
    </button>
    <textarea
      id="chat-input"
      class="chat-composer__input"
      placeholder="พิมพ์ข้อความ..."
      rows="1"
      maxlength="4000"
      disabled
    ></textarea>
    <button type="submit" class="chat-composer__send" id="chat-send" disabled aria-label="ส่ง">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m22 2-7 20-4-9-9-4z"/><path d="M22 2 11 13"/></svg>
    </button>
  </form>
</div>

<!-- Socket.io client (CDN — pin version เพื่อกัน breaking change) -->
<script src="https://cdn.socket.io/4.7.5/socket.io.min.js" crossorigin="anonymous"></script>
<%- include('../partials/foot', { pageScript: 'chat-room' }) %>
