<%- include('../partials/head') %>
<div class="app-shell app-shell--with-header" style="display: flex; flex-direction: column; min-height: 100dvh;">
  <%- include('../partials/header', { title: 'สมัครเป็นช่าง', back: true, backHref: '/home' }) %>
  <div style="padding: var(--space-md) var(--space-md) 0;">
    <div class="alert alert--info" style="margin-bottom: var(--space-md);">
      <span class="alert__icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
      </span>
      <span>เลือกสกิลที่คุณรับงาน เพื่อให้ระบบจับคู่กับลูกค้าที่ต้องการ</span>
    </div>

    <div class="field">
      <label class="field__label" for="resume">แนะนำตัว / ประวัติงาน (ไม่บังคับ)</label>
      <textarea class="textarea" id="resume" rows="3" placeholder="เช่น ช่างไฟฟ้า 10 ปี รับงานทั่วกรุงเทพ"></textarea>
    </div>
    <h3 class="section-title" style="margin-bottom: 4px;">เลือกสกิลที่คุณรับงาน</h3>
  </div>

  <div id="skill-mount" style="flex: 1;"></div>

  <div style="padding: var(--space-md); border-top: 1px solid var(--border); background: rgba(255,255,255,0.92); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); position: sticky; bottom: 0;">
    <div data-form-error></div>
    <button type="button" class="btn btn--primary btn--block btn--lg" id="submit-btn">สมัครเป็นช่าง (0 สกิล)</button>
  </div>
</div>
<script src="/static/js/auth.js?v=<%= assetV %>"></script>
<script src="/static/js/api.js?v=<%= assetV %>"></script>
<script src="/static/js/ui.js?v=<%= assetV %>"></script>
<script src="/static/js/skill-tree.js?v=<%= assetV %>"></script>
<script src="/static/js/pages/become-worker.js?v=<%= assetV %>"></script>
</body>
</html>
