<%- include('../partials/head') %>
<div class="app-shell app-shell--with-header">
  <%- include('../partials/header', { title: 'เวลาทำงาน', back: true, backHref: '/profile' }) %>
  <div class="page-content">
    <div class="alert alert--info" style="margin-bottom: var(--space-md);">
      <span class="alert__icon" aria-hidden="true">🕘</span>
      <span>บอกลูกค้าว่าคุณรับงานวันไหน เวลาไหนบ้าง — ไม่เลือกเลยจะขึ้นว่า "ติดต่อได้ตลอด"</span>
    </div>

    <div data-form-error></div>
    <div id="schedule-mount">
      <div class="loading-block"><div class="spinner"></div></div>
    </div>

    <button type="button" class="btn btn--primary btn--block btn--lg" id="save-btn"
            style="margin-top: var(--space-lg);">บันทึกเวลาทำงาน</button>
  </div>
</div>
<script src="/static/js/schedule-picker.js?v=<%= assetV %>"></script>
<%- include('../partials/foot', { pageScript: 'worker-schedule' }) %>
