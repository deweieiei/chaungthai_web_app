  </div>
</div>
<script src="/static/js/auth.js?v=<%= assetV %>"></script>
<script src="/static/js/api.js?v=<%= assetV %>"></script>
<script src="/static/js/ui.js?v=<%= assetV %>"></script>
<script src="/static/js/skill-tree.js?v=<%= assetV %>"></script>
<script src="/static/js/worker-resolver.js?v=<%= assetV %>"></script>
<script src="/static/js/pages/edit-skills.js?v=<%= assetV %>"></script>
</body>
</html>
