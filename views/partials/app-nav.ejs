<%
  // แถบเมนูบน — ใช้ทุกขนาดจอ (จอเล็กยุบเมนูเข้าปุ่ม ☰)
  // locals: activeTab — 'home' | 'search' | 'jobs' | 'chat' | 'profile'
  const tab = typeof activeTab !== 'undefined' ? activeTab : null;
  const on = (name) => (name === tab ? ' is-active' : '');

  //  เมนูต่างกันตามฝั่งบัญชี — ซ่อน/แสดงด้วย CSS จาก data-account บน <html>
  //  (ตั้งไว้ใน head.ejs ตั้งแต่ก่อนวาด body เมนูอีกฝั่งจะได้ไม่โผล่แวบ)
  //
  //  แผนที่ = เครื่องมือของผู้ว่าจ้างไว้หาช่าง → ฝั่งช่างไม่มี
  //  ฝั่งช่างใช้ /worker/home เป็นหน้าหลักแทน
  const NAV = [
    { key: 'home',   href: '/home',        icon: '🗺️', label: 'แผนที่',   only: 'employer' },
    { key: 'home',   href: '/worker/home', icon: '🏠', label: 'หน้าหลัก', only: 'worker' },
    { key: 'jobs',   href: '/jobs',        icon: '💼', label: 'งาน' },
    { key: 'chat',   href: '/chat',        icon: '💬', label: 'แชต' },
  ];
%>
<nav class="app-nav" aria-label="เมนูหลัก">
  <div class="app-nav__bar">
    <a href="/home" class="app-nav__brand">
      <img src="/static/images/logo-96.png" alt="" width="34" height="34">
      <span>ช่างไทย</span>
    </a>

    <!-- เมนูเต็ม — จอกว้างเห็นเรียงกัน จอแคบซ่อนไว้ในปุ่ม ☰ -->
    <div class="app-nav__links" id="app-nav-links">
      <% NAV.forEach(function (item) { %>
        <a href="<%= item.href %>" class="app-nav__link<%= on(item.key) %>"
           <%= item.only ? 'data-only="' + item.only + '"' : '' %>>
          <span aria-hidden="true"><%= item.icon %></span> <%= item.label %>
        </a>
      <% }); %>
      <a href="/profile" class="app-nav__link app-nav__link--me<%= on('profile') %>">
        <span id="app-nav-avatar" aria-hidden="true"></span>
        <span id="app-nav-name">โปรไฟล์</span>
      </a>
    </div>

    <button type="button" class="app-nav__burger" id="app-nav-burger"
            aria-label="เปิดเมนู" aria-expanded="false" aria-controls="app-nav-links">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    // เติมชื่อ + รูปจาก storage (auth.js/ui.js โหลดท้าย body)
    if (window.Auth) {
      var u = Auth.getUser();
      if (u) {
        var nameEl = document.getElementById('app-nav-name');
        if (nameEl) nameEl.textContent = u.user_name || 'โปรไฟล์';
        var avEl = document.getElementById('app-nav-avatar');
        if (avEl && window.UI) avEl.innerHTML = UI.avatar(u, 'sm');
      }
    }

    // ปุ่ม ☰ (จอแคบ)
    var burger = document.getElementById('app-nav-burger');
    var links = document.getElementById('app-nav-links');
    if (!burger || !links) return;

    function setOpen(open) {
      links.classList.toggle('is-open', open);
      burger.classList.toggle('is-open', open);
      burger.setAttribute('aria-expanded', open ? 'true' : 'false');
    }

    burger.addEventListener('click', function (e) {
      e.stopPropagation();
      setOpen(!links.classList.contains('is-open'));
    });

    // กดที่อื่นหรือกด Esc = ปิด
    document.addEventListener('click', function (e) {
      if (!links.contains(e.target)) setOpen(false);
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') setOpen(false);
    });
  });
</script>
