<!doctype html>
<html lang="th">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover, maximum-scale=5">
  <meta name="theme-color" content="#970000">
  <meta name="format-detection" content="telephone=no">
  <meta name="description" content="ChaungThai — จับคู่คนเก่งกับคนมีปัญหา ในราคาที่จ่ายไหว">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="ChaungThai">
  <title><%= title %> · ChaungThai</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Sarabun:wght@400;500;600;700;800;900&display=swap">

  <link rel="stylesheet" href="/static/css/theme.css?v=<%= assetV %>">
  <link rel="stylesheet" href="/static/css/components.css?v=<%= assetV %>">
  <link rel="stylesheet" href="/static/css/map.css?v=<%= assetV %>">

  <!-- อ่านฝั่งบัญชีตั้งแต่ก่อนวาด body — ถ้ารอ JS ท้ายหน้า เมนูของอีกฝั่งจะโผล่แวบนึงก่อนหาย
       CSS ใน map.css ใช้ค่านี้ซ่อน/แสดงเมนูตามฝั่ง (worker / employer) -->
  <script>
    (function () {
      var t = 'employer';
      try {
        var u = JSON.parse(localStorage.getItem('chaungthai_user') || 'null');
        if (u && u.user_account_type === 'worker') t = 'worker';
      } catch (e) { /* storage ปิดอยู่ — ถือเป็นผู้ว่าจ้าง */ }
      document.documentElement.setAttribute('data-account', t);
    })();
  </script>

  <link rel="icon" type="image/png" sizes="48x48" href="/static/images/logo-48.png">
  <link rel="icon" type="image/png" sizes="96x96" href="/static/images/logo-96.png">
  <link rel="icon" type="image/png" sizes="192x192" href="/static/images/logo.png">
  <link rel="apple-touch-icon" href="/static/images/logo.png">
</head>
<body>
