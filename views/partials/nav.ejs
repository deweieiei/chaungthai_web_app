<nav class="nav">
  <a href="/" class="brand">ChaungThai</a>
  <div class="nav-links">
    <a href="/" id="nav-home" style="display:none">หน้าหลัก</a>
    <a href="/profile" id="nav-profile" style="display:none">โปรไฟล์</a>
    <a href="/search-workers" id="nav-search" style="display:none">หาช่าง</a>
    <a href="/become-worker" id="nav-becomeworker" style="display:none">สมัครเป็นช่าง</a>
    <a href="#" id="nav-logout" style="display:none" onclick="doLogout(event)">ออกจากระบบ</a>
    <a href="/login" id="nav-login">เข้าสู่ระบบ</a>
    <a href="/register" id="nav-register">สมัครสมาชิก</a>
  </div>
</nav>
<script>
  // toggle nav ตามสถานะ login
  (function () {
    const user = getUser();
    const ids = ['nav-home','nav-profile','nav-search','nav-becomeworker','nav-logout'];
    const guestIds = ['nav-login','nav-register'];
    if (user) {
      ids.forEach(id => document.getElementById(id).style.display = '');
      guestIds.forEach(id => document.getElementById(id).style.display = 'none');
      // ถ้าเป็น worker แล้ว ซ่อนปุ่ม "สมัครเป็นช่าง"
      if (user.user_role === 'worker' || user.user_role === 'admin') {
        document.getElementById('nav-becomeworker').style.display = 'none';
      }
    }
  })();
  function doLogout(e) {
    e.preventDefault();
    clearToken();
    window.location.href = '/';
  }
</script>
