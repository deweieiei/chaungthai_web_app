<%
  // locals: activeTab — 'home' | 'search' | 'chat' | 'profile'
  const tab = typeof activeTab !== 'undefined' ? activeTab : null;
  function activeCls(name) { return name === tab ? ' bottom-nav__item--active' : ''; }
%>
<nav class="bottom-nav" aria-label="เมนูหลัก">
  <a href="/home" class="bottom-nav__item<%= activeCls('home') %>" aria-current="<%= tab === 'home' ? 'page' : 'false' %>">
    <span class="bottom-nav__icon" aria-hidden="true">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9.5L12 3l9 6.5V20a1 1 0 0 1-1 1h-5v-7h-6v7H4a1 1 0 0 1-1-1V9.5Z"/></svg>
    </span>
    <span>หน้าหลัก</span>
  </a>
  <a href="/search-workers" class="bottom-nav__item<%= activeCls('search') %>" aria-current="<%= tab === 'search' ? 'page' : 'false' %>">
    <span class="bottom-nav__icon" aria-hidden="true">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
    </span>
    <span>หาช่าง</span>
  </a>
  <a href="/jobs" class="bottom-nav__item<%= activeCls('jobs') %>" aria-current="<%= tab === 'jobs' ? 'page' : 'false' %>">
    <span class="bottom-nav__icon" aria-hidden="true">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 7h-3V5a2 2 0 0 0-2-2H9a2 2 0 0 0-2 2v2H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/><path d="M9 5h6v2H9z"/></svg>
      <span class="bottom-nav__badge bottom-nav__badge--count" id="job-unread-badge" hidden></span>
    </span>
    <span>งาน</span>
  </a>
  <a href="/chat" class="bottom-nav__item<%= activeCls('chat') %>" aria-current="<%= tab === 'chat' ? 'page' : 'false' %>">
    <span class="bottom-nav__icon" aria-hidden="true">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      <span class="bottom-nav__badge bottom-nav__badge--count" id="chat-unread-badge" hidden></span>
    </span>
    <span>แชต</span>
  </a>
  <a href="/profile" class="bottom-nav__item<%= activeCls('profile') %>" aria-current="<%= tab === 'profile' ? 'page' : 'false' %>">
    <span class="bottom-nav__icon" aria-hidden="true">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
    </span>
    <span>โปรไฟล์</span>
  </a>
</nav>
