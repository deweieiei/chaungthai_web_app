<%
  // locals: title, back (boolean), backHref (optional), rightAction (HTML)
  const showBack = typeof back !== 'undefined' && back;
  const _backHref = typeof backHref !== 'undefined' ? backHref : null;
%>
<header class="app-header">
  <% if (showBack) { %>
    <% if (_backHref) { %>
      <a href="<%= _backHref %>" class="app-header__back" aria-label="ย้อนกลับ">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
      </a>
    <% } else { %>
      <button type="button" class="app-header__back" onclick="history.back()" aria-label="ย้อนกลับ">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
      </button>
    <% } %>
  <% } else { %>
    <span class="app-header__back" aria-hidden="true"></span>
  <% } %>
  <h1 class="app-header__title"><%= title %></h1>
  <% if (typeof rightAction !== 'undefined' && rightAction) { %>
    <%- rightAction %>
  <% } else { %>
    <span class="app-header__action" aria-hidden="true"></span>
  <% } %>
</header>
