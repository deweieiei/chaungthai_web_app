<%- include('partials/head') %>
<div class="app-shell">
  <div class="page-content page-content--narrow" style="display: flex; flex-direction: column; justify-content: center; min-height: 100dvh; text-align: center;">
    <div style="width: 96px; height: 96px; margin: 0 auto; background: var(--danger-soft); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--danger);">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z"/><path d="M12 9v4M12 17h.01"/></svg>
    </div>
    <h1 style="margin-top: var(--space-md);">ระบบมีปัญหา</h1>
    <p class="text-muted">กรุณาลองอีกครั้งในอีกสักครู่</p>
    <% if (typeof error !== 'undefined' && error) { %>
      <pre style="background: var(--surface-alt); padding: 14px; border-radius: var(--radius-md); text-align: left; overflow: auto; font-size: 12px; margin-top: var(--space-md); border: 1px solid var(--border);"><%= error %></pre>
    <% } %>
    <div style="margin-top: var(--space-lg);">
      <a href="/home" class="btn btn--primary btn--block btn--lg">กลับหน้าหลัก</a>
    </div>
  </div>
</div>
</body>
</html>
