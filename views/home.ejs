<%- include('partials/head') %>
<div class="app-shell app-shell--with-nav">
  <div class="page-content">
    <div class="hero">
      <div class="hero__greeting">สวัสดี 👋</div>
      <h2 class="hero__name" id="hero-name">ผู้ใช้</h2>
      <div class="hero__sub">ยินดีต้อนรับสู่ ChaungThai</div>
    </div>

    <h3 class="section-title">ทำอะไรในวันนี้?</h3>

    <a href="/search-workers" class="action-card">
      <div class="action-card__icon" aria-hidden="true">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
      </div>
      <div class="action-card__main">
        <h4 class="action-card__title">หาช่าง</h4>
        <p class="action-card__sub">ค้นหาคนเก่งใกล้บ้านคุณ</p>
      </div>
      <div class="action-card__caret" aria-hidden="true">›</div>
    </a>

    <a href="/become-worker" class="action-card" id="become-worker-card">
      <div class="action-card__icon action-card__icon--success" aria-hidden="true">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.4 2.6a2.1 2.1 0 1 1 3 3L12 15l-4 1 1-4 9.4-9.4Z"/></svg>
      </div>
      <div class="action-card__main">
        <h4 class="action-card__title">สมัครเป็นช่าง</h4>
        <p class="action-card__sub">ลงทะเบียนรับงานในระบบ</p>
      </div>
      <div class="action-card__caret" aria-hidden="true">›</div>
    </a>

    <a href="/worker/edit-skills" class="action-card hidden" id="edit-skills-card">
      <div class="action-card__icon action-card__icon--info" aria-hidden="true">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76Z"/></svg>
      </div>
      <div class="action-card__main">
        <h4 class="action-card__title">แก้ไขสกิลของฉัน</h4>
        <p class="action-card__sub">อัปเดตสกิลที่รับงาน</p>
      </div>
      <div class="action-card__caret" aria-hidden="true">›</div>
    </a>

    <div id="worker-stats" class="hidden" style="margin-top: var(--space-lg);">
      <h3 class="section-title">ของฉัน</h3>
      <div class="stat-grid">
        <div class="stat-box">
          <div class="stat-box__icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 9V5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v4a2 2 0 0 0 0 6v4a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-4a2 2 0 0 0 0-6Z"/><path d="M13 5v2M13 17v2M13 11v2"/></svg>
          </div>
          <div class="stat-box__value" id="stat-tickets">-</div>
          <div class="stat-box__label">บัตรคงเหลือ</div>
        </div>
        <div class="stat-box">
          <div class="stat-box__icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          </div>
          <div class="stat-box__value" id="stat-jobs">-</div>
          <div class="stat-box__label">งานที่รับ</div>
        </div>
      </div>
    </div>
  </div>
  <%- include('partials/bottom-nav', { activeTab: 'home' }) %>
</div>
<%- include('partials/foot', { pageScript: 'home' }) %>
