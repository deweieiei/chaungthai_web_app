<%- include('../partials/site-head') %>
<%- include('../partials/site-header', { activeNav: 'how' }) %>

<main class="wrap">

  <section class="page-hero">
    <h1>วิธีใช้งาน</h1>
    <p>บัญชีเดียว ใช้ได้ทั้งฝั่ง "หาช่าง" และฝั่ง "รับงาน"</p>
  </section>

  <div class="two-col">
    <!-- ---------- ฝั่งคนจ้าง ---------- -->
    <div class="col-card">
      <h3>🔍 ฝั่งคนที่อยากจ้าง</h3>
      <ol class="flow">
        <li>
          <b>เปิดแผนที่</b>
          ดูคนมีฝีมือที่ว่างอยู่รอบตัว กรองตามหมวดงานที่ต้องการได้เลย
        </li>
        <li>
          <b>เลือกคนที่ถูกใจ</b>
          กดที่หมุดเพื่อดูโปรไฟล์ ความสามารถ และผลงานที่ผ่านมา
        </li>
        <li>
          <b>แชทคุยรายละเอียด</b>
          ถามราคา ถามคิว ตกลงเงื่อนไขกันในเว็บ ไม่ต้องแลกเบอร์ก่อน
        </li>
        <li>
          <b>กดจ้าง</b>
          ระบุรายละเอียดงาน ราคา วันเริ่ม–วันเสร็จ แล้วส่งให้ช่างกดรับ
        </li>
        <li>
          <b>ปิดงาน &amp; ให้ดาว</b>
          งานเสร็จแล้วกดปิดทั้งสองฝ่าย แล้วให้คะแนนกัน
        </li>
      </ol>
    </div>

    <!-- ---------- ฝั่งช่าง ---------- -->
    <div class="col-card">
      <h3>🛠️ ฝั่งคนรับงาน</h3>
      <ol class="flow">
        <li>
          <b>สมัครสมาชิก</b>
          ใช้อีเมลเดียว สมัครเสร็จกด "สมัครเป็นช่าง" ต่อได้ทันที ไม่ต้องกรอกซ้ำ
        </li>
        <li>
          <b>เลือกความสามารถ</b>
          เลือกจาก 189 บริการ ว่ารับงานอะไรได้บ้าง
        </li>
        <li>
          <b>ปักหมุดจุดรับงาน</b>
          บอกว่าอยู่แถวไหน และยอมเดินทางในรัศมีกี่กิโลเมตร
        </li>
        <li>
          <b>ยืนยันตัวตน</b>
          ส่งเอกสารให้เจ้าหน้าที่ตรวจ ผ่านแล้วได้เครื่องหมายยืนยัน คนจ้างเห็นตำแหน่งชัดขึ้น
        </li>
        <li>
          <b>รอรับงาน</b>
          ขึ้นแผนที่ให้คนแถวนั้นเห็น มีคนทักมาก็ตกลงกันได้เลย
        </li>
      </ol>
    </div>
  </div>

  <div class="prose">
    <h2>กติกาที่ควรรู้</h2>
    <ul>
      <li><strong>รับทีละงาน</strong> — ช่างที่กำลังรับงานอยู่จะหายจากแผนที่ พอปิดงานแล้วค่อยกลับขึ้นมา คนจ้างจึงเจอแต่คนที่ว่างจริง</li>
      <li><strong>ปิดงานต้องครบสองฝ่าย</strong> — งานจะยังไม่จบจนกว่าทั้งคนจ้างและช่างจะกดยืนยัน</li>
      <li><strong>ตำแหน่งเปิดเผย 2 ระดับ</strong> — คนทั่วไปเห็นแค่พื้นที่คร่าว ๆ ประมาณ 1 กิโลเมตร ส่วนคนที่ยืนยันตัวตนแล้วจึงเห็นตำแหน่งใกล้เคียงของจริง เพื่อความปลอดภัยของทุกคน</li>
      <li><strong>รีวิวมาจากงานจริง</strong> — ให้ดาวได้เฉพาะงานที่จบในระบบ และให้ได้ครั้งเดียวต่อหนึ่งงาน</li>
    </ul>
  </div>

  <section class="cta-band">
    <h2>ลองใช้เลย</h2>
    <p>สมัครฟรี ไม่มีค่าแรกเข้า</p>
    <div class="hero-cta">
      <a class="btn btn-primary btn-lg" href="/register">สมัครสมาชิก</a>
      <a class="btn btn-outline btn-lg" href="/home">เปิดแผนที่</a>
    </div>
  </section>

</main>

<%- include('../partials/site-footer') %>
